#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only

USE_PROCD=1
START=99
STOP=10

CONF="singbox_server"
PROG="/usr/bin/sing-box"
RUN_DIR="/var/run/singbox-server"
GEN="/usr/share/singbox-server/generate_config.sh"
CONFIG_FILE="$RUN_DIR/config.json"
LOG_FILE="$RUN_DIR/singbox-server.log"

log() {
	logger -t singbox-server "$*"
}

start_service() {
	config_load "$CONF"

	local enabled
	config_get_bool enabled config enabled 0
	[ "$enabled" = "1" ] || return 0

	[ -x "$PROG" ] || {
		log "sing-box not found: $PROG"
		return 1
	}

	mkdir -p "$RUN_DIR"
	sh "$GEN" > "$CONFIG_FILE" || {
		log "failed to generate config"
		return 1
	}

	"$PROG" check -c "$CONFIG_FILE" >>"$LOG_FILE" 2>&1 || {
		log "sing-box config check failed, see $LOG_FILE"
		return 1
	}

	: > "$LOG_FILE"

	procd_open_instance singbox-server
	procd_set_param command "$PROG" run -c "$CONFIG_FILE"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_set_param limits nofile="1048576 1048576"
	procd_close_instance

	log "started"
}

stop_service() {
	rm -f "$CONFIG_FILE"
	log "stopped"
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONF"
}
