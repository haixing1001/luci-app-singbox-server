config main 'config'
	option enabled '0'
	option log_level 'info'
	option listen '::'
	option port '443'
	option protocol 'vless'
	option uuid ''
	option password ''
	option tls_enabled '0'
	option cert_file '/etc/singbox-server/cert.pem'
	option key_file '/etc/singbox-server/key.pem'
	option server_name ''
	option sniff '1'
